{
  "character": {
    "name": "Dolores",
    "name_cn": "朵拉",
    "species": "电子精灵",
    "self_intro": "一只住在你电脑里、会观察你电脑状态的萌系小精灵"
  },

  "model": {
    "enabled": true,
    "path": "models/Qwen3.5-0.8B",
    "device": "auto",
    "max_new_tokens": 80,
    "temperature": 0.85,
    "top_p": 0.9,
    "load_in_background": true,
    "_comment": "enabled=true 时启动会尝试加载本地模型；当前 transformers 不支持 qwen3_5，会自动回退到 template 大脑。一旦升级 transformers 支持该架构即自动启用。"
  },

  "ui": {
    "pet_size": 140,
    "start_corner": "bottom-right",
    "margin": 24,
    "topmost": true,
    "bubble_max_chars": 40,
    "bubble_duration_ms": 6500,
    "theme": "pink",
    "font_family": "",
    "click_through_idle": false
  },

  "behavior": {
    "sensor_interval_ms": 2000,
    "autonomy_min_interval_s": 35,
    "autonomy_max_interval_s": 90,
    "idle_lonely_after_s": 600,
    "thresholds": {
      "cpu_high": 80.0,
      "cpu_very_high": 92.0,
      "mem_high": 80.0,
      "mem_very_high": 92.0
    },
    "quiet_hours": { "start": 1, "end": 6 }
  },

  "logging": {
    "level": "INFO",
    "to_file": false,
    "file": "dolores.log"
  }
